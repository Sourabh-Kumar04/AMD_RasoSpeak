# RasoSpeak v2 — Environment Variables
# No GPU required - works on 4GB RAM using external APIs

# ═══════════════════════════════════════════════════
# DEFAULT LLM PROVIDER
# Options: google, nvidia, openai, anthropic, huggingface, openrouter, opencode, xai, deepseek
# ═══════════════════════════════════════════════════
DEFAULT_PROVIDER=google

# ═══════════════════════════════════════════════════
# GOOGLE GEMINI (Default #1)
# Get API key: https://aistudio.google.com/app/apikey
# ═══════════════════════════════════════════════════
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash-exp

# ═══════════════════════════════════════════════════
# NVIDIA NIM (Default #2)
# Get API key: https://build.nvidia.com/
# ═══════════════════════════════════════════════════
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# ═══════════════════════════════════════════════════
# OPENAI (ChatGPT)
# Get API key: https://platform.openai.com/api-keys
# ═══════════════════════════════════════════════════
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ═══════════════════════════════════════════════════
# ANTHROPIC (Claude)
# Get API key: https://console.anthropic.com/
# ═══════════════════════════════════════════════════
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ═══════════════════════════════════════════════════
# HUGGINGFACE
# Get API key: https://huggingface.co/settings/tokens
# ═══════════════════════════════════════════════════
HF_API_KEY=
HF_MODEL=meta-llama/Llama-3.2-1B-Instruct

# ═══════════════════════════════════════════════════
# OPENROUTER (80+ models via single API)
# Get API key: https://openrouter.ai/settings
# ═══════════════════════════════════════════════════
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-exp

# ═══════════════════════════════════════════════════
# OPENCODE
# Get API key: https://opencode.ai/
# ═══════════════════════════════════════════════════
OPENCODE_API_KEY=

# ═══════════════════════════════════════════════════
# XAI (Grok)
# Get API key: https://console.x.ai/
# ═══════════════════════════════════════════════════
XAI_API_KEY=
XAI_MODEL=grok-2-1212

# ═══════════════════════════════════════════════════
# DEEPSEEK
# Get API key: https://platform.deepseek.com/
# ═══════════════════════════════════════════════════
DEEPSEEK_API_KEY=

# ═══════════════════════════════════════════════════
# TRANSCRIPTION (Optional)
# Set OPENAI_WHISPER_API_KEY to use OpenAI Whisper API instead of browser
# ═══════════════════════════════════════════════════
OPENAI_WHISPER_API_KEY=

# ═══════════════════════════════════════════════════
# SEARCH (Optional)
# ═══════════════════════════════════════════════════
TAVILY_API_KEY=
SERP_API_KEY=
BRAVE_API_KEY=

# ═══════════════════════════════════════════════════
# NOTIFICATIONS (Optional)
# ═══════════════════════════════════════════════════
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PUSHOVER_TOKEN=
PUSHOVER_USER_KEY=

# ═══════════════════════════════════════════════════
# SERVER CONFIG
# ═══════════════════════════════════════════════════
PORT=7860
ALLOWED_ORIGINS=*

# ═══════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════
API_KEY=