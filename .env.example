# RasoSpeak v2 — Environment Configuration
# Copy this to .env and fill in your AMD Developer Cloud details

# ── AMD DEVELOPER CLOUD ───────────────────────────────
# Your vLLM server endpoint (running Qwen2.5 on MI300X)
VLLM_HOST=localhost
VLLM_PORT=8001

# AMD device identifier (ROCm appears as "cuda" to PyTorch)
AMD_DEVICE=cuda
AMD_GPU_ID=0

# ── REDIS (optional — for persistent session history) ─
REDIS_HOST=localhost
REDIS_PORT=6379

# ── MODELS ───────────────────────────────────────────
# These are downloaded automatically on first run
WHISPER_MODEL=large-v3
SCORING_MODEL=Qwen/Qwen2.5-7B-Instruct
COACHING_MODEL=Qwen/Qwen2.5-7B-Instruct
SEGMENTATION_MODEL=Qwen/Qwen2.5-3B-Instruct

# ── SERVER ────────────────────────────────────────────
PORT=8000
LOG_LEVEL=info
