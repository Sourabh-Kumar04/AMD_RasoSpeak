# RasoSpeak v2 — Environment Configuration
# Copy this to .env and fill in your AMD Developer Cloud details

# ══════════════════════════════════════════════════════
# AMD DEVELOPER CLOUD (Required for AI inference)
# ══════════════════════════════════════════════════════
VLLM_HOST=localhost
VLLM_PORT=8001
AMD_DEVICE=cuda
AMD_GPU_ID=0

# ══════════════════════════════════════════════════════
# REDIS (optional — for persistent session history)
# ══════════════════════════════════════════════════════
REDIS_HOST=localhost
REDIS_PORT=6379

# ══════════════════════════════════════════════════════
# MODELS (downloaded automatically on first run)
# ══════════════════════════════════════════════════════
WHISPER_MODEL=large-v3
SCORING_MODEL=Qwen/Qwen2.5-7B-Instruct
COACHING_MODEL=Qwen/Qwen2.5-7B-Instruct
SEGMENTATION_MODEL=Qwen/Qwen2.5-3B-Instruct
QA_MODEL=Qwen/Qwen2.5-7B-Instruct

# ══════════════════════════════════════════════════════
# SERVER CONFIG
# ══════════════════════════════════════════════════════
PORT=8000
LOG_LEVEL=info

# ══════════════════════════════════════════════════════
# Q&A AGENT - Multi-provider AI (Choose one or more)
# ══════════════════════════════════════════════════════
# Default: qwen_local (uses vLLM). Change to: openai, anthropic, google, xai
QA_DEFAULT_PROVIDER=qwen_local

# OpenAI GPT (get key from https://platform.openai.com/api-keys)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic Claude (get key from https://console.anthropic.com)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini (get key from https://aistudio.google.com/app/apikey)
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# xAI Grok (get key from https://console.x.ai)
XAI_API_KEY=
XAI_MODEL=grok-2-1212

# ══════════════════════════════════════════════════════
# SEARCH AGENT - Web Search (at least one recommended)
# ══════════════════════════════════════════════════════
# Tavily (recommended - https://app.tavily.com)
TAVILY_API_KEY=

# SerpAPI (Google results - https://serpapi.com)
SERP_API_KEY=

# Brave Search (https://brave.com/search/api/)
BRAVE_API_KEY=

# ══════════════════════════════════════════════════════
# RECORDING & ANALYTICS
# ══════════════════════════════════════════════════════
RECORDINGS_PATH=./recordings
RECORD_AUDIO_ENABLED=true
RECORD_QA_ENABLED=true
ANALYTICS_ENABLED=true
